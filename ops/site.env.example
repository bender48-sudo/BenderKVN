# Shared public endpoints (NO secrets). Copy to `ops/site.env` (gitignored)
# so all Python ops scripts and optional `deploy-node.sh` sourcing share one place.

# HTTPS panel API base (matches Remnawave / Caddy)
export PANEL_URL=https://k9x2m1.conntest.xyz:2053

# Alias for older docs / shell — same as PANEL_URL (optional)
export PANEL_PUBLIC_URL=https://k9x2m1.conntest.xyz:2053

# Subscription HTTP host (Happ / subscription-page) — primary public name
export SUB_PUBLIC_ORIGIN=https://p4n7q.conntest.xyz:2053

# P2-RED-SUB-01: alternate name(s), comma-separated (same shortId path /api/sub/…)
export SUB_ALT_PUBLIC_ORIGINS=https://k9x2m1.conntest.xyz:2053

# P2-RED-BOOT-01: public HTTPS JSON ops status (backup if Telegram API blocked)
export STATUS_MIRROR_ORIGIN=https://k9x2m1.conntest.xyz:2053
export STATUS_MIRROR_PATH=api/ops/status.json

# P5-COM-01: public HTML status (no Telegram required)
export PUBLIC_STATUS_ORIGIN=https://k9x2m1.conntest.xyz:2053
export PUBLIC_STATUS_PATH=/status

# P3-FLOW-01 / P3-FLOW-14: portal (site + Telegram Mini App — same URL)
export PUBLIC_BOOTSTRAP_ORIGIN=https://k9x2m1.conntest.xyz:2053
export PUBLIC_BOOTSTRAP_PATH=/start
export PUBLIC_PORTAL_ORIGIN=https://k9x2m1.conntest.xyz:2053
export PUBLIC_PORTAL_PATH=/portal

# P3-FLOW-02: personal setup page (token appended by bot)
export PUBLIC_SETUP_PATH=/setup

# P3-FLOW-12: set in BotFather to PUBLIC_PORTAL_ORIGIN + PUBLIC_PORTAL_PATH
# export TELEGRAM_WEBAPP_URL=https://k9x2m1.conntest.xyz:2053/portal/

# Subscription template UUID from panel «Subscription templates»
export REMNA_TEMPLATE_UUID=9ebbce97-ae45-4f39-a7e6-d7e675a94a73

# ru-monitor / relay (public IP of RU-relay host for SSH-based SNI probes)
export RU_RELAY_HOST=72.56.0.145
export RU_RELAY_SSH_PORT=3344

# Optional: suffix for smoke GET (default matches monitor.sh)
# export SUB_MONITOR_PROBE_SUFFIX=api/sub/JLCF43RGjyq4ML78Qcsbq7Kf2
