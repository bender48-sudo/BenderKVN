# Local secret vault for ops/render_compose.py.
#
# Copy this file to .secrets/vault.env and fill in real values pulled from
# the production hosts (see docs/SECRETS.md §1 for paths).
#
# This file is git-ignored. NEVER commit .secrets/vault.env.

# Telegram bot ("Bender_KVN_bot")
BOT_TOKEN=

# Long-lived JWT for /api/* (panel issue, exp ~2299)
REMNA_API_TOKEN=

# Base64 cert/key bundle for node<->panel TLS
SECRET_KEY_NODE_JWT_BUNDLE=

# HMAC secrets for panel JWT signing
JWT_AUTH_SECRET=
JWT_API_TOKENS_SECRET=

# Postgres (panel)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres

# Prometheus basic-auth pass
METRICS_PASS=

# Webhook HMAC header (currently disabled)
WEBHOOK_SECRET_HEADER=

# Cloudflare DNS API token (if/when DNS-ACME enabled)
CLOUDFLARE_TOKEN=
